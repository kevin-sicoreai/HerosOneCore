# ══════════════════════════════════════════════════════════════════
#  HerosOneCore unified config — single source of truth for ALL middleware
#
#  Copy to dev.env / prod.env (both gitignored) and fill in real values.
#  The two profiles MUST keep an identical key set; only values differ.
#  Loaded exclusively via `source scripts/env.sh` (reads APP_ENV, defaults dev).
# ══════════════════════════════════════════════════════════════════

# ─── profile ────────────────────────────────────────────────────────
APP_ENV=dev                          # dev | prod

# ─── security ───────────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=720
ADMIN_USER=admin
ADMIN_PASS=admin

# ─── metadata DBs (server Postgres; one DB per service) ─────────────
# Each service's DATABASE_URL is derived as ${META_DB_BASE_URL}/${DB_PREFIX}<svc>
META_DB_BASE_URL=postgresql+psycopg://USER:PASS@HOST:5432
DB_PREFIX=hoc_dev_                    # prod: hoc_

# ─── source DB (HR business data the platform ingests) ──────────────
SOURCE_DB_HOST=HOST
SOURCE_DB_PORT=5432
SOURCE_DB_USER=USER
SOURCE_DB_PASSWORD=PASS
SOURCE_DB_NAME=herosonecore_ops_dev      # prod: herosonecore_ops

# ─── data plane (MinIO / S3) ────────────────────────────────────────
STORAGE_BACKEND=s3                   # s3 | local (emergency fallback)
S3_ENDPOINT=http://HOST:9000
S3_ACCESS_KEY=KEY
S3_SECRET_KEY=SECRET
S3_BUCKET=herosonecore-dev              # prod: herosonecore
S3_REGION=us-east-1
LOCAL_STORAGE_DIR=./_dataplane       # used only when STORAGE_BACKEND=local

# ─── orchestration (Airflow) ────────────────────────────────────────
USE_AIRFLOW=false                    # prod: true
AIRFLOW_URL=http://HOST:8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_DAG_ID=run_dbt_pipeline

# ─── catalog / lineage (OpenMetadata) ───────────────────────────────
CATALOG_PUBLISHER=none               # none | openmetadata (prod)
OM_API_URL=http://HOST:8585/api
OM_TOKEN=

# ─── LLM (assist service) ───────────────────────────────────────────
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_DISPLAY_NAME="DeepSeek V4 Flash"

# ─── web frontend (Next.js; dev profile runs `next dev`, prod builds) ─
WEB_PORT=3000

# ─── service mesh (FastAPI services; local in both profiles) ────────
AUTH_PORT=8005
DATA_PORT=8000
PIPELINE_PORT=8001
ONTOLOGY_PORT=8003
GOV_PORT=8004
ASSIST_PORT=8006
ANALYSIS_PORT=8008
AUTH_API_URL=http://127.0.0.1:8005
DATA_API_URL=http://127.0.0.1:8000
PIPELINE_API_URL=http://127.0.0.1:8001
ONTOLOGY_API_URL=http://127.0.0.1:8003
GOV_API_URL=http://127.0.0.1:8004
ASSIST_API_URL=http://127.0.0.1:8006
ANALYSIS_API_URL=http://127.0.0.1:8008


# ═══════════════════════════════════════════════
#  Sicore monorepo — 根级 .gitignore（ui/ + ask-server/ 等）
#  规则不带前导斜杠，可匹配任意子目录（monorepo 友好）
# ═══════════════════════════════════════════════

# ───────────── 依赖 ─────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# ───────────── 构建产物 / 中间产物 ─────────────
# Next.js
.next/
out/
next-env.d.ts
# 通用构建输出
dist/
build/
.turbo/
.vercel/
.cache/
*.tsbuildinfo

# ───────────── 测试 / 覆盖率 ─────────────
coverage/
.nyc_output/

# ───────────── 环境变量 / 密钥 ─────────────
.env
.env.*
!.env.example
config/*.env
!config/example.env
*.pem
*.key

# ───────────── 日志 ─────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ───────────── 后端 / 微服务中间产物 ─────────────
# Go
bin/
*.exe
*.out
# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
# Java / gradle / maven
target/
.gradle/

# ───────────── 容器 / 编排本地产物 ─────────────
*.local
docker-compose.override.yml

# ───────────── 操作系统 ─────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ───────────── 编辑器 / IDE ─────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ───────────── Claude Code 本地配置 ─────────────
.claude/settings.local.json

# AskDelphi Python service artifacts
*.egg-info/
data_service.db
analysis.db
analysis_service.db
assist_service.db
marketplace_service.db
app_builder_service.db
dev.db
*.sqlite3
_dataplane/

# Pipeline service artifacts
pipeline*.db
_pipelines/

# Ontology service artifacts
ontology.db

# Governance service artifacts
governance.db

# Auth service artifacts
auth.db

# Service env_file for the compose stack — injected as container env vars
# (docker compose reads each KEY=VALUE literally; NO shell, so JSON values are
# written UNQUOTED here, unlike config/dev.env which is sourced by bash).
#
#   cp deploy/hoc.env.example /workspace/herosonecore/config/hoc.env
#   # then paste the real JWT_SECRET / LLM_API_KEY / OM_TOKEN
#
# Routing points at compose service names (not 127.0.0.1). Middleware
# (Postgres/MinIO/OM/vLLM) is reached at the 10.1.0.4 host IP. Per-service
# DATABASE_URL is set in docker-compose.yml, not here.

APP_ENV=dev

# --- security ---
JWT_SECRET=<fill: copy from config/dev.env or generate a new 32-byte hex>
JWT_EXPIRE_MINUTES=720
ADMIN_USER=admin
ADMIN_PASS=admin
# auth service bootstraps this admin on first start (create_all seeds it):
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# --- source DB (business data the platform ingests) ---
SOURCE_DB_HOST=10.1.0.4
SOURCE_DB_PORT=5433
SOURCE_DB_USER=shop
SOURCE_DB_PASSWORD=shop
SOURCE_DB_NAME=herosonecore_ops_dev
SOURCE_DB_URL=postgresql://shop:shop@10.1.0.4:5433/herosonecore_ops_dev

# --- data plane (MinIO on 10.1.0.4) ---
STORAGE_BACKEND=s3
S3_ENDPOINT=http://10.1.0.4:9000
S3_ACCESS_KEY=sicore
S3_SECRET_KEY=sicore123
S3_BUCKET=herosonecore-dev
S3_REGION=us-east-1
LOCAL_STORAGE_DIR=/app/_dataplane

# --- orchestration (Airflow disabled in dev) ---
USE_AIRFLOW=false
AIRFLOW_URL=http://10.1.0.4:8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_DAG_ID=run_dbt_pipeline

# --- catalog / lineage (OpenMetadata on 10.1.0.4) ---
CATALOG_PUBLISHER=openmetadata
OM_API_URL=http://10.1.0.4:8585/api
OM_TOKEN=<fill: OpenMetadata admin JWT; ~1h TTL, refresh before a catalog sync>

# --- LLM (assist) ---
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=<fill: DeepSeek API key>
LLM_MODEL=deepseek-v4-flash
LLM_DISPLAY_NAME=DeepSeek V4 Flash
# Extra selectable model(s), raw JSON (unquoted — see header note). Local vLLM
# Qwen on the 10.1.0.4 GPU box; keep host IP even from a container.
LLM_MODELS=[{"id":"qwen-local","display_name":"Qwen3.5-35B (本地)","base_url":"http://10.1.0.4:8000/v1","api_key":"EMPTY","model":"/data/models/huggingface/Qwen3.5-35B-A3B-NVFP4"}]
LLM_DEFAULT_MODEL=

# --- inter-service routing (compose service names) ---
AUTH_API_URL=http://auth:8005
DATA_API_URL=http://data:8000
PIPELINE_API_URL=http://pipeline:8001
ONTOLOGY_API_URL=http://ontology:8003
GOV_API_URL=http://governance:8004
ASSIST_API_URL=http://assist:8006
ANALYSIS_API_URL=http://analysis:8008
APP_BUILDER_API_URL=http://app-builder:8002
# pydantic field-name aliases (analysis / assist / governance):
ONTOLOGY_SERVICE_URL=http://ontology:8003
GOVERNANCE_SERVICE_URL=http://governance:8004
ANALYSIS_SERVICE_URL=http://analysis:8008

# Compose interpolation values — read automatically by `docker compose` from
# deploy/.env. Kept separate from the services' env_file so the DB credential
# is not committed inside docker-compose.yml.
#
#   cp deploy/.env.example deploy/.env   # then adjust
#
# Metadata Postgres (one DB per service: ${META_DB_BASE_URL}/${DB_PREFIX}<svc>).
# On 10.1.0.4 this is the herosone-core-src container published on :5433.
META_DB_BASE_URL=postgresql+psycopg://shop:shop@10.1.0.4:5433
DB_PREFIX=hoc_dev_

# Host port the nginx gateway is published on → http://10.1.0.4:${GATEWAY_PORT}
GATEWAY_PORT=3000
